# Terraform working files
.terraform/
.terraform.lock.hcl

# Sensitive generated files — never commit these
terraform.tfvars
*.tfvars
!terraform.tfvars.example

# State files — use a remote backend in production
terraform.tfstate
terraform.tfstate.backup
terraform.tfstate.d/

# Crash log
crash.log
crash.*.log

# Override files (local-only config)
override.tf
override.tf.json
*_override.tf
*_override.tf.json
