# .env — macOS host configuration for Talos-on-mac
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
# Alternatively, set these as environment variables before running tofu apply,
# or let the scripts prompt you interactively.

# macOS sudo password — used by setup-dns.sh and scripts/trust-ca.sh
# to write /etc/resolver and trust the cluster CA in System Keychain.
# Leave empty to be prompted at runtime.
SUDO_PASSWORD=
