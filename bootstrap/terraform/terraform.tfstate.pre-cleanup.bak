ork:\n    interfaces:\n      - interface: enp0s1     # Tart/Apple VZ virtio-net interface name\n        dhcp: true\n        vip:\n          ip: 192.168.64.100  # TALOS_VIP — updated by 04-generate-configs.sh if overridden\n","\"machine\":\n  \"install\":\n    \"image\": \"ghcr.io/siderolabs/installer:v1.13.0\"\n"],"docs":null,"examples":null,"id":"talos-tart-ha","kubernetes_version":"1.35.2","machine_configuration":"version: v1alpha1\ndebug: false\npersist: true\nmachine:\n    type: controlplane\n    token: osjr9e.qe3f632wbv10rfr5\n    ca:\n        crt: \n        key: LS0tLS1CRUdJTiBFRDI1NTE5IFBSSVZBVEUgS0VZLS0tLS0KTUM0Q0FRQXdCUVlESzJWd0JDSUVJSHY5ZGhVNVpWWS9hOUJ2SkY3bWthMXp0MTY2OFZCL284YUNFM1NiUVk2ZQotLS0tLUVORCBFRDI1NTE5IFBSSVZBVEUgS0VZLS0tLS0K\n    certSANs: []\n    kubelet:\n        image: ghcr.io/siderolabs/kubelet:v1.35.2\n        extraArgs:\n            rotate-server-certificates: \"true\"\n        defaultRuntimeSeccompProfileEnabled: true\n        disableManifestsDirectory: true\n    network:\n        interfaces:\n            - interface: enp0s1\n              dhcp: true\n              vip:\n                ip: 192.168.64.100\n    install:\n        disk: /dev/vda\n        image: ghcr.io/siderolabs/installer:v1.13.0\n        wipe: false\n        grubUseUKICmdline: true\n    sysctls:\n        net.core.bpf_jit_enable: \"1\"\n        net.ipv4.conf.all.rp_filter: \"0\"\n        net.ipv4.conf.default.rp_filter: \"0\"\n    features:\n        diskQuotaSupport: true\n        kubePrism:\n            enabled: true\n            port: 7445\n        hostDNS:\n            enabled: true\n            forwardKubeDNSToHost: true\n    kernel:\n        modules:\n            - name: br_netfilter\n    nodeLabels:\n        node.kubernetes.io/exclude-from-external-load-balancers: \"\"\ncluster:\n    id: fMtTMStYMbVMOuu4n05KByKCZexwMgvSS_io0MH28H0=\n    secret: WWDinh1dREMihRAFNWf1qStPDFcQcUOIJdpAwH67FTM=\n    controlPlane:\n        endpoint: https://192.168.64.6:6443\n    clusterName: talos-tart-ha\n    network:\n        cni:\n            name: none\n        dnsDomain: cluster.local\n        podSubnets:\n            - 10.244.0.0/16\n        serviceSubnets:\n            - 10.96.0.0/12\n    token: 3llxas.3pkz9jy0f91jmy4d\n    secretboxEncryptionSecret: zXD0nZunJODLihhzuX/0EniQF6hYTUOBjCWdiVeh42s=\n    ca:\n        crt: \n        key: \n    aggregatorCA:\n        crt: \n        key: \n    serviceAccount:\n        key: \n    apiServer:\n        image: registry.k8s.io/kube-apiserver:v1.35.2\n        admissionControl:\n            - name: PodSecurity\n              configuration:\n                apiVersion: pod-security.admission.config.k8s.io/v1alpha1\n                defaults:\n                    audit: restricted\n                    audit-version: latest\n                    enforce: baseline\n                    enforce-version: latest\n                    warn: restricted\n                    warn-version: latest\n                exemptions:\n                    namespaces:\n                        - kube-system\n                    runtimeClasses: []\n                    usernames: []\n                kind: PodSecurityConfiguration\n        auditPolicy:\n            apiVersion: audit.k8s.io/v1\n            kind: Policy\n            rules:\n                - level: Metadata\n    controllerManager:\n        image: registry.k8s.io/kube-controller-manager:v1.35.2\n    proxy:\n        disabled: true\n        image: registry.k8s.io/kube-proxy:v1.35.2\n    scheduler:\n        image: registry.k8s.io/kube-scheduler:v1.35.2\n    discovery:\n        enabled: true\n        registries:\n            kubernetes:\n                disabled: true\n            service: {}\n    etcd:\n        ca:\n            crt: \n            key: \n---\napiVersion: v1alpha1\nkind: HostnameConfig\nauto: stable\n","machine_secrets":{"certs":{"etcd":{"cert":"","key":""},"k8s":{"cert":"","key":""},"k8s_aggregator":{"cert":"","key":""},"k8s_serviceaccount":{"key":""},"os":{"cert"