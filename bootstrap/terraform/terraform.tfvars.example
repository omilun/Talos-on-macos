# ─────────────────────────────────────────────────────────────────────────────
# terraform.tfvars  —  copy this file, change the GitHub URL, run tofu apply.
# This file is gitignored — never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ❶  Point Flux at YOUR fork of this repo (required)
flux_git_repository_url = "https://github.com/YOUR_USERNAME/Talos-on-macos"

# ❷  Node pools — adjust CPU/RAM to match your Mac's available resources.
#    Default below: 6 VMs, ~24 GB RAM, ~18 vCPU total.
#    See docs/node-pools.md for tainted pools, infra nodes, and more recipes.
node_pools = [
  { name = "cp",     role = "controlplane", count = 3, cpu = 2, memory_gb = 4 },
  { name = "worker", role = "worker",        count = 3, cpu = 2, memory_gb = 4 },
]

# ❸  Everything below is optional — defaults work on any Apple Silicon Mac.

# cluster_name       = "talos-tart-ha"    # used in kubeconfig context + domain names
# talos_version      = "v1.13.0"
# kubernetes_version = "1.35.2"
# disk_size_gb       = 20                 # per VM
# allow_scheduling_on_controlplane = false  # true = CPs also run workloads

# Sudo password for /etc/resolver + Keychain trust steps.
# Leave commented to be prompted once during tofu apply, OR:
#   export TF_VAR_macos_sudo_password="yourpassword"  (never commit this)
# macos_sudo_password = ""

# For private repos only:
# flux_github_token = ""   # or: export TF_VAR_flux_github_token="ghp_..."
